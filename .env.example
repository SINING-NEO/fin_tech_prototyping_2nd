# Required for AI responses (get key at https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-key-here

# Model selection (gpt-4o-mini recommended for prototyping)
OPENAI_MODEL=gpt-4o-mini

# Set to "true" to use mock responses when no API key is configured
USE_MOCK_LLM=true

# Demo password for Financial Representative agent portal login
AGENT_DEMO_PASSWORD=prudential2025
